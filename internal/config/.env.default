# tick configuration

# Pricing & FX providers
EQUITY_PRICE_PROVIDER=finnhub
CRYPTO_PRICE_PROVIDER=coingecko
FX_PROVIDER=frankfurter
NEWS_PROVIDER=newsapiorg

# Required if using finnhub
FINNHUB_API_KEY=""
NEWSAPIORG_API_KET=""

# Cache settings
CACHE_ENABLED=true
CACHE_PRICE_TTL=15m
CACHE_FX_TTL=12h

# LLM (optional)
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3.1