# tick configuration

# Pricing & FX providers
PRICE_PROVIDER=finnhub
FX_PROVIDER=frankfurter

# Required if using finnhub
FINNHUB_API_KEY=""

# Cache settings
CACHE_ENABLED=true
CACHE_PRICE_TTL=15m
CACHE_FX_TTL=12h

# LLM (optional)
LLM_ENABLED=false
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434
LLM_MODEL=llama3