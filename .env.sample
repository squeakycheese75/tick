# =========================
# General
# =========================

# Enable in-memory caching for prices and FX rates
CACHE_ENABLED=true

# =========================
# Pricing
# =========================

# Price data provider:
# - static   (mock/test data)
# - finnhub  (live market data)
PRICE_PROVIDER=static

# Finnhub API key (required if PRICE_PROVIDER=finnhub)
FINNHUB_API_KEY=your_key_here

# =========================
# FX Rates
# =========================

# FX rate provider:
# - static        (fixed/mock rates)
# - frankfurter   (https://www.frankfurter.app/)
FX_PROVIDER=static

# =========================
# Cache Configuration
# =========================

# Price cache TTL (e.g. 15m, 1h)
CACHE_PRICE_TTL=15m

# FX cache TTL (e.g. 12h, 24h)
CACHE_FX_TTL=12h

# =========================
# LLM (Optional)
# =========================

# Enable LLM-powered features (e.g. summaries)
LLM_ENABLED=true

# LLM provider:
# - ollama
LLM_PROVIDER=ollama

# Base URL for Ollama API
LLM_BASE_URL=http://localhost:11434

# Model to use (tag optional)
# Examples:
# - llama3
# - llama3:latest
# - mistral
#
# If no tag is provided, ":latest" will be assumed.
LLM_MODEL=llama3